# ============================================================
# Configuración SMTP para el envío de emails (invitación de
# cambio de contraseña). Copiá este archivo a .env y completá
# los valores. NO commitees el .env (ya está en .gitignore).
# ============================================================

# --- Gmail SMTP ---
# Requiere 2FA activado en la cuenta y un "App Password" de 16
# dígitos generado en https://myaccount.google.com/apppasswords
# (la contraseña normal de Gmail NO funciona).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu-cuenta@gmail.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxx

# Remitente que figura en el "From". Por defecto usa SMTP_USERNAME.
SMTP_FROM=tu-cuenta@gmail.com
SMTP_FROM_NAME=AETERNA

# --- App ---
# URL base del frontend, usada para armar el link del email.
FRONTEND_URL=http://localhost:5173

# Minutos de validez del token de invitación.
PASSWORD_RESET_EXPIRATION_MINUTES=10
